---
import Default from '@astrojs/starlight/components/MobileTableOfContents.astro'

const { toc } = Astro.locals.starlightRoute
---

{
  toc && (
    <div class="[&_nav]:backdrop-blur [&_summary]:border-b-(--sl-color-hairline)">
      <Default />
    </div>
  )
}

<script>
  // Guard against duplicate 'starlight-toc' custom element registration.
  // Starlight registers it from both the desktop and mobile TOC components,
  // which throws on the second call. Only guard this specific element name.
  const originalDefine = customElements.define.bind(customElements);
  customElements.define = function(name: string, constructor: CustomElementConstructor, options?: ElementDefinitionOptions) {
    if (name === 'starlight-toc' && customElements.get(name)) {
      return;
    }
    originalDefine(name, constructor, options);
  };
</script>
