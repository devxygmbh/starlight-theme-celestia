---
import config from "virtual:starlight/user-config";
import VersionSelect from "./VersionSelect.astro";

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;

// Resolve the logo src to a public path.
// Starlight's default SiteTitle uses virtual:starlight/user-images which goes through
// Astro's image pipeline, causing re-processing on each page load and logo flicker.
// We render the logo as a plain <img> from the public directory instead.
let logoSrc: string | undefined;
let logoAlt = "";
if (config.logo) {
  logoAlt = config.logo.alt || "";
  if ("src" in config.logo) {
    // Single logo — resolve the public path from the src string
    const raw = typeof config.logo.src === "string" ? config.logo.src : "";
    logoSrc = raw.replace(/^\.\/public/, "");
  }
}
---

<div class="site-title-wrapper">
  <a href={siteTitleHref} class="site-title sl-flex">
    {logoSrc && <img alt={logoAlt} src={logoSrc} class="celestia-logo" />}
    <span class:list={{ "sr-only": config.logo?.replacesTitle }} translate="no">
      {siteTitle}
    </span>
  </a>
  <VersionSelect />
</div>

<style>
  .site-title-wrapper {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-title {
    align-items: center;
    gap: var(--sl-nav-gap);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }

  .celestia-logo {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: 0 50%;
  }

  span {
    overflow: hidden;
  }
</style>
